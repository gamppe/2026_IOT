# 7-3win.py (윈도우 노트북에서 실행, C:\pi\ch07에 저장)
import paho.mqtt.client as mqtt

def on_connect(client, userdata, flag, rc, prop=None):
	client.subscribe("room/temp") # 메시지 구독 신청

def on_message(client, userdata, msg):
